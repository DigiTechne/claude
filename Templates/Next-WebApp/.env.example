# Copy to .env.local and fill in your values

# Database (docker-compose: docker compose up -d postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/template_next_stack

# Auth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3000

# Email (Resend - get key at resend.com; in dev, emails log to console if unset)
RESEND_API_KEY=re_your_key_here

# Public URL (used for absolute links in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
